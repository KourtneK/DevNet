<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/stylecss/feed.css">
    <title>DevNet - Feed</title>
</head>
<body>
    <header>
        <h1>Feed</h1>
    </header>

    <%- include('partials/header') %>

    <main>
        <% if (user) { %>
        <section class="caixa-postagem">
            <form action="/postar" method="POST">
                <textarea name="conteudo" placeholder="Diga algo ou cole seu código aqui..." required></textarea>

                <div class="opcoes-post">
                    <select name="tipo">
                        <option value="texto">📝 Texto</option>
                        <option value="codigo">💻 Código</option>
                        <option value="imagem">🖼️ Imagem (URL)</option>
                        <option value="video">🎥 Vídeo (YouTube)</option>
                        <option value="repo">📂 Repositório GitHub</option>
                    </select>
                    <input type="url" name="linkMidia" placeholder="Link da mídia ou repositório (opcional)">
                </div>

                <div class="form-footer">
                    <button type="submit" class="btn button-feed">Publicar na DevNet</button>
                </div>
            </form>
        </section>
        <% } %>

        <section class="lista-posts">
            <% posts.forEach(post => { %>
            <article class="card-post">
                <header class="card-header">
                    <img src="<%= post.avatar %>" class="avatar-min">
                    <div class="user-info">
                        <strong>@<%= post.usuario %></strong>
                        <small><%= post.data %></small>
                    </div>
                    
                    <% if (user && user.username === post.usuario) { %>
                    <form action="/deletar/<%= post.id %>" method="POST" style="margin-left: auto;">
                        <button type="submit" class="btn-delete">🗑️</button>
                    </form>
                    <% } %>
                </header>

                <div class="card-body">
                    <% if (post.tipo === 'codigo') { %>
                        <pre><code><%= post.conteudo %></code></pre>
                    <% } else { %>
                        <p><%= post.conteudo %></p>
                    <% } %>

                    <% if (post.tipo === 'imagem' && post.linkMidia) { %>
                        <img src="<%= post.linkMidia %>" class="midia-post">  21]
                    <% } else if (post.tipo === 'video' && post.linkMidia) { %>
                        <iframe width="100%" height="315" 
                                src="<%= post.linkMidia.replace('watch?v=', 'embed/') %>" 
                                [_start]frameborder="0" allowfullscreen></iframe>
                    <% } else if (post.tipo === 'repo' && post.linkMidia) { %>
                        <div class="repo-box">
                            <a href="<%= post.linkMidia %>" target="_blank">📂 Ver Repositório no GitHub</a>
                        </div>
                    <% } %>
                </div>
            </article>
            <% }) %>
        </section>
    </main>

    <footer>© 2026 DevNet - Todos os direitos reservados</footer>
</body>
</html>