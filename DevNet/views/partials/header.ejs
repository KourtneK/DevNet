<nav class="navbar">
    <div class="nav-links">
        <% if (paginaAtual !== 'home') { %><button class="btn button-home"><a href="/">Home</a></button><% } %>

        <% if (paginaAtual !== 'feed') { %><button class="btn button-feed"><a href="/feed">Feed</a></button><% } %>

        <% if (paginaAtual !== 'perfil') { %><button class="btn button-perfil"><a href="/perfil">Perfil</a></button><% } %>

        <% if (paginaAtual !== 'config') { %><button class="btn button-cfg"><a href="/config">Configurações</a></button><% } %>
    </div>

    <% if (user) { %>
        <div class="profile-pill-top-right">
            <img src="<%= user._json.avatar_url %>" class="avatar-nav" alt="Avatar">
            <span class="username-nav">@<%= user.username %></span>
            <a href="/logout" class="logout-link">Sair</a>
        </div>
    <% } else { %>
        <div class="profile-pill-top-right">
             <button class="btn button-home" style="background-color: #333; padding: 10px 20px;">
                <a href="/auth/github">Login</a>
            </button>
        </div>
    <% } %>
</nav>